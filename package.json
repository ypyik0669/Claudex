{
  "name": "claudex",
  "version": "0.1.0",
  "description": "Desktop coding-agent app for Claude Code CLI with a Codex-inspired workspace.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/ypyik0669/Claudex.git"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis zip",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "com.ypyik0669.claudex",
    "productName": "Claudex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico",
      "artifactName": "Claudex-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "Claudex-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claudex"
    }
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@vitejs/plugin-react": "5.0.4",
    "lucide-react": "^0.468.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
